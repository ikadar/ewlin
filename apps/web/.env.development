# API Configuration
# In development, we use mock data by default
VITE_USE_MOCK=true

# API URL for local backend testing (when VITE_USE_MOCK=false)
# Uncomment and set to test against local backend:
# VITE_API_URL=http://localhost:8000/api/v1

# Mercure Hub URL for real-time SSE updates (when VITE_USE_MOCK=false)
# VITE_MERCURE_URL=http://localhost:3000/.well-known/mercure
