# Docker build ignore file for Flux monorepo
# Used by: validation-service build AND frontend multi-stage build

# Node modules (will be installed in container)
**/node_modules/

# Built artifacts (will be built in container)
**/dist/
**/*.tsbuildinfo

# Test files
**/tests/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
**/vitest.config.ts
**/cypress.config.ts
**/playwright.config.ts
**/__tests__/
**/test/
**/sonar-*

# Development files
**/.git/
**/.gitignore
**/README.md
**/CHANGELOG.md
**/*.md

# IDE
**/.vscode/
**/.idea/

# Docker files (don't need to copy these into the build)
**/Dockerfile
**/.dockerignore
docker/

# Services/apps not needed for Docker builds
services/php-api/
apps/qa-api/
apps/qa-tracker/
apps/web/cypress/
apps/web/playwright/
apps/web/playwright-report/
apps/web/test-results/
apps/web/.scannerwork/
apps/web/scripts/
docs/

# Environment files
.env
.env.*
!.env.example
