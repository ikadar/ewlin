# Production Environment Variables
# Copy to .env.production and fill in the values
# Usage: docker compose --env-file .env.production -f docker-compose.yml -f docker-compose.prod.yml up -d

# =============================================================================
# Database (MariaDB)
# =============================================================================
MARIADB_ROOT_PASSWORD=change_me_root_password_min_32_chars
MARIADB_DATABASE=flux_scheduler
MARIADB_USER=flux_user
MARIADB_PASSWORD=change_me_user_password_min_32_chars
MARIADB_PORT=3306

# =============================================================================
# PHP API (Symfony)
# =============================================================================
APP_ENV=prod
APP_DEBUG=0
APP_SECRET=change_me_random_32_char_hex_string

# Database URL (uses variables above)
DATABASE_URL=mysql://${MARIADB_USER}:${MARIADB_PASSWORD}@mariadb:${MARIADB_PORT}/${MARIADB_DATABASE}?serverVersion=10.11.0-MariaDB

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://redis:6379

# =============================================================================
# Validation Service
# =============================================================================
VALIDATION_SERVICE_URL=http://validation-service:3001

# =============================================================================
# Domain (for CORS, etc.)
# =============================================================================
DOMAIN=flux.example.com
CORS_ALLOW_ORIGIN=https://flux.example.com
