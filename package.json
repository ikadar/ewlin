{
  "name": "ewlin",
  "version": "0.0.8",
  "private": true,
  "description": "Flux Print Shop Scheduling System - Host Application",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "dev:qa": "concurrently -n api,tracker -c yellow,cyan \"pnpm --filter qa-api dev\" \"pnpm --filter qa-tracker dev\"",
    "test:e2e": "pnpm --filter @flux/e2e-tests test:e2e"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["cypress", "esbuild"]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
