# Apache VirtualHost for Flux Scheduler
# Copy to: /etc/apache2/sites-available/flux.conf
# Enable with: sudo a2ensite flux.conf && sudo systemctl reload apache2
#
# Prerequisites:
#   sudo a2enmod proxy proxy_http ssl headers
#   sudo certbot certonly --apache -d flux.example.com

<VirtualHost *:80>
    ServerName flux.example.com

    # Redirect all HTTP to HTTPS
    Redirect permanent / https://flux.example.com/
</VirtualHost>

<VirtualHost *:443>
    ServerName flux.example.com

    # SSL Configuration
    SSLEngine on
    SSLCertificateFile /etc/letsencrypt/live/flux.example.com/fullchain.pem
    SSLCertificateKeyFile /etc/letsencrypt/live/flux.example.com/privkey.pem

    # Modern SSL settings
    SSLProtocol all -SSLv3 -TLSv1 -TLSv1.1
    SSLHonorCipherOrder off
    SSLSessionTickets off

    # Security headers
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Proxy to Docker Nginx
    ProxyPreserveHost On
    ProxyPass / http://127.0.0.1:8080/
    ProxyPassReverse / http://127.0.0.1:8080/

    # WebSocket support (if needed later)
    RewriteEngine On
    RewriteCond %{HTTP:Upgrade} websocket [NC]
    RewriteCond %{HTTP:Connection} upgrade [NC]
    RewriteRule ^/?(.*) ws://127.0.0.1:8080/$1 [P,L]

    # Logging
    ErrorLog ${APACHE_LOG_DIR}/flux_error.log
    CustomLog ${APACHE_LOG_DIR}/flux_access.log combined
</VirtualHost>
